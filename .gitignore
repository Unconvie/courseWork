# --- Тестовые данные --------------------------------------------------------
# Большие тестовые наборы и выходные файлы программы не должны попадать
# в репозиторий. Папка data/samples/ оставлена в git только через .gitkeep.
/data/samples/**
!/data/samples/.gitkeep
/data/output/
